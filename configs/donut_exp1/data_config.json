{
  "data_dir": "./dataset/ocr/donut",
  "real_data_path": "./dataset/ocr/donut/real",
  "synthetic_data_path": "./dataset/ocr/donut/synth",
  "cache_dir": "./data_cache",
  "enable_caching": true,
  "apply_augmentation": true,
  "augmentation_prob": 0.3,
  "max_rotation": 8.0,
  "noise_level": 0.05,
  "color_jitter": true,
  "elastic_transform": true,
  "random_perspective": true,
  "max_samples_per_split": 1000,
  "image_extensions": [
    ".jpg",
    ".jpeg",
    ".png",
    ".bmp"
  ],
  "image_size": [384, 384]
}